# -----------------------------------------------------------------------------
# Frontend runtime mode
# -----------------------------------------------------------------------------
# VITE_API_URL controls where broadband lookups are dispatched.
#
#   /demo                       -> DEMO MODE. No backend network calls are made.
#                                  Data is read from /public/data/postcodes.json.
#
#   /api                        -> LIVE MODE. Requests go to
#                                  ${VITE_API_URL}/check?pc=...  (i.e. /api/check?pc=...)
#
# NOTE: Vite inlines this value at BUILD time into the content-hashed bundle.
#       Do not rely on runtime config injection (keeps CloudFront hosting safe).
VITE_API_URL=/demo

# Shared secret sent as the `X-Origin-Verify` header in LIVE mode so the Lambda
# can perform Zero-Trust ingress verification. Leave blank in demo mode.
VITE_ORIGIN_VERIFY_SECRET=
